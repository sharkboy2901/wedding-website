<%- include('partials/head', { pageTitle: 'Welcome', config }) %>
<% const activePage = 'home'; %>
<%- include('partials/nav', { config, activePage, livestreamVisible }) %>
<%- include('partials/botanicals') %>

<main>
  <!-- Hero -->
  <section class="hero" aria-label="Welcome">
    <div class="hero-content">
      <p class="hero-eyebrow">We're getting married</p>
      <h1 class="hero-names"><%= config.coupleNames %></h1>
      <p class="hero-date"><%= config.weddingDate %></p>
      <p class="hero-venue"><%= config.venueName %><% if (config.venueLocation) { %>, <%= config.venueLocation %><% } %></p>
      <a href="/gallery" class="btn btn-primary hero-cta">View Gallery</a>
    </div>
