          <div class="detail-icon" aria-hidden="true">♡</div>
          <h3>Ceremony</h3>
          <p><%= config.weddingDate %></p>
          <p><%= config.ceremonyTime %></p>
          <p><%= config.venueName %></p>
        </div>
        <div class="detail-card">
          <div class="detail-icon" aria-hidden="true">♪</div>
          <h3>Reception</h3>
          <p>Following the ceremony</p>
          <p><%= config.receptionTime %></p>
          <p><%= config.venueName %></p>
        </div>
        <div class="detail-card">
          <div class="detail-icon" aria-hidden="true">✦</div>
          <h3>Dress Code</h3>
          <p><%= config.dressCode %></p>
        </div>
        <div class="detail-card">
          <div class="detail-icon" aria-hidden="true">📷</div>
          <h3>Share Moments</h3>
          <p>Upload your photos</p>
          <p>from our special day</p>
          <a href="/upload" class="detail-link">Share a photo &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation tiles -->
  <section class="nav-tiles-section" aria-label="Explore">
    <div class="container">
      <div class="nav-tiles">
        <a href="/our-story" class="nav-tile">
          <span class="nav-tile-icon" aria-hidden="true">💌</span>
          <span class="nav-tile-title">Our Story</span>
          <span class="nav-tile-sub">How it all began</span>
        </a>
        <a href="/gallery" class="nav-tile">
          <span class="nav-tile-icon" aria-hidden="true">📷</span>
          <span class="nav-tile-title">Gallery</span>
          <span class="nav-tile-sub">Photos & memories</span>
        </a>
        <a href="/upload" class="nav-tile">
          <span class="nav-tile-icon" aria-hidden="true">🌸</span>
          <span class="nav-tile-title">Share a Photo</span>
          <span class="nav-tile-sub">Upload your memory</span>
        </a>
        <% if (livestreamVisible) { %>
        <a href="/livestream" class="nav-tile nav-tile--live">
          <span class="nav-tile-icon" aria-hidden="true">📺</span>
          <span class="nav-tile-title">Watch Live</span>
          <span class="nav-tile-sub">Join us remotely</span>
        </a>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Livestream section: full embed when admin enables homepage player -->
  <% if (livestreamHomepage && livestreamChannel) { %>
  <section class="home-livestream-section" aria-label="Live stream">
    <div class="container">
      <h2 class="section-title">Watch Live</h2>
      <p class="section-sub">Join us from wherever you are</p>
      <div class="home-livestream-player">
        <iframe
          src="https://player.twitch.tv/?channel=<%= encodeURIComponent(livestreamChannel) %>&parent=mk-wedding.up.railway.app&autoplay=false"
          height="480"
          width="100%"
          allowfullscreen
          frameborder="0"
          title="Wedding livestream"
        ></iframe>
      </div>
      <div style="text-align:center;margin-top:1.25rem;">
        <a href="/livestream" class="btn btn-secondary">Open Full Livestream Page &rarr;</a>
      </div>
    </div>
  </section>
  <% } else if (livestreamVisible && livestreamChannel) { %>
  <!-- Livestream available but not embedded on homepage — show a CTA banner -->
  <section class="home-livestream-cta-section" aria-label="Live stream">
    <div class="container">
      <div class="livestream-cta-card">
        <div class="livestream-cta-icon" aria-hidden="true">📺</div>
        <div class="livestream-cta-text">
          <h2>We're Live!</h2>
          <p>Watch our ceremony live from wherever you are.</p>
        </div>
        <a href="/livestream" class="btn btn-primary">Watch Live &rarr;</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Guest Moments -->
  <section class="home-moments-section" id="moments">
    <div class="container">
      <h2 class="section-title">Guest Moments</h2>
      <p class="section-sub">Capture and share the magic of our day</p>
      <div class="moments-upload-cta">
        <p class="moments-upload-text">Taken a beautiful photo at the wedding? Share it with us — your memories may be featured right here!</p>
        <a href="/upload" class="btn btn-primary">Share Your Photo</a>
      </div>
      <% if (featuredPhotos && featuredPhotos.length > 0) { %>
        <div class="moments-grid">
          <% featuredPhotos.forEach(function(photo) { %>
            <div class="moment-card">
              <img src="/uploads/approved/<%= photo.filename %>" alt="Guest photo<%= photo.uploader_name ? ' by ' + photo.uploader_name : '' %>" loading="lazy">
              <% if (photo.uploader_name) { %><p class="moment-name"><%= photo.uploader_name %></p><% } %>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="moments-empty">Photos shared by guests will appear here.</p>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer', { config }) %>
