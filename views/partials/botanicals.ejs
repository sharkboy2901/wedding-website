<%# Botanical side decorations — watercolor-style olive branches, white lilies, baby's breath %>
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- ── Watercolor filter: subtle organic warp + soft edges ── -->
    <filter id="bot-wc" x="-5%" y="-5%" width="110%" height="110%">
      <feTurbulence type="fractalNoise" baseFrequency="0.022" numOctaves="2" seed="7" result="n"/>
      <feDisplacementMap in="SourceGraphic" in2="n" scale="1.3"/>
    </filter>
    <filter id="bot-soft" x="-5%" y="-5%" width="110%" height="110%">
      <feGaussianBlur stdDeviation="0.25"/>
    </filter>

    <!-- ── Olive leaf gradients (silvery sage to deep olive green) ── -->
    <linearGradient id="bot-leafDk" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"  stop-color="#5e7048" stop-opacity="0.95"/>
      <stop offset="55%" stop-color="#3f4e2c" stop-opacity="0.92"/>
      <stop offset="100%" stop-color="#2a361a" stop-opacity="0.9"/>
    </linearGradient>
    <linearGradient id="bot-leafLt" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"  stop-color="#b8c4a4" stop-opacity="0.7"/>
      <stop offset="100%" stop-color="#8a9a78" stop-opacity="0.75"/>
    </linearGradient>

    <!-- ── Olive fruit gradients ── -->
    <radialGradient id="bot-oliveG" cx="32%" cy="28%" r="68%">
      <stop offset="0%"  stop-color="#d4dea0"/>
      <stop offset="38%" stop-color="#a4b270"/>
      <stop offset="78%" stop-color="#6a7c44"/>
      <stop offset="100%" stop-color="#3e4a26"/>
    </radialGradient>
    <radialGradient id="bot-oliveD" cx="32%" cy="28%" r="68%">
      <stop offset="0%"  stop-color="#6a5670"/>
      <stop offset="42%" stop-color="#36283c"/>
      <stop offset="80%" stop-color="#1c1424"/>
      <stop offset="100%" stop-color="#0a060e"/>
    </radialGradient>

    <!-- ── White lily petal gradient ── -->
    <linearGradient id="bot-petal" x1="50%" y1="100%" x2="50%" y2="0%">
      <stop offset="0%"   stop-color="#e6dec8"/>
      <stop offset="45%"  stop-color="#f6f0e2"/>
      <stop offset="100%" stop-color="#fdfbf4"/>
    </linearGradient>
    <linearGradient id="bot-petalShade" x1="50%" y1="100%" x2="50%" y2="0%">
      <stop offset="0%"   stop-color="#d8d0bc"/>
      <stop offset="100%" stop-color="#f0eadb"/>
    </linearGradient>

    <!-- ── Baby's breath flower ── -->
    <radialGradient id="bot-bb" cx="38%" cy="32%" r="62%">
      <stop offset="0%"   stop-color="#ffffff"/>
      <stop offset="70%"  stop-color="#f4efe4"/>
      <stop offset="100%" stop-color="#d6cebe"/>
    </radialGradient>

    <!-- ── Lily sepal/bud gradient ── -->
    <linearGradient id="bot-bud" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"  stop-color="#4e6234" stop-opacity="0.95"/>
      <stop offset="55%" stop-color="#7a9050" stop-opacity="0.95"/>
      <stop offset="100%" stop-color="#3a4a22" stop-opacity="0.9"/>
    </linearGradient>

    <!-- ─────────────────────────────────────────────────────────
         REUSABLE: lanceolate olive leaf (points up from origin)
         ───────────────────────────────────────────────────────── -->
    <symbol id="bot-leaf" overflow="visible">
      <!-- darker base layer -->
      <path d="M 0,-1 C -2.4,-7 -3.8,-17 -2.8,-27 C -1.8,-32 -0.5,-34 0,-34
               C 0.5,-34 1.8,-32 2.8,-27 C 3.8,-17 2.4,-7 0,-1 Z"
            fill="url(#bot-leafDk)" stroke="#33421e" stroke-width="0.38"/>
      <!-- watercolor light overlay (slightly offset, lighter) -->
      <path d="M 0,-3 C -1.6,-8 -2.6,-15 -2.0,-24 C -1.4,-29 -0.4,-31 0,-31
               C 0.4,-31 -0.4,-29 -0.4,-26 L -0.4,-26 C -0.4,-22 -0.8,-15 -1.4,-8 Z"
            fill="url(#bot-leafLt)" opacity="0.55"/>
      <!-- center vein -->
      <line x1="0" y1="-3" x2="0" y2="-31" stroke="#56683e" stroke-width="0.32" opacity="0.55"/>
    </symbol>

    <!-- Smaller olive leaf -->
    <symbol id="bot-leaf-sm" overflow="visible">
      <path d="M 0,-1 C -1.8,-6 -2.8,-13 -2.0,-21 C -1.3,-25 -0.3,-26 0,-26
               C 0.3,-26 1.3,-25 2.0,-21 C 2.8,-13 1.8,-6 0,-1 Z"
            fill="url(#bot-leafDk)" stroke="#33421e" stroke-width="0.32"/>
      <path d="M 0,-3 C -1.2,-7 -1.9,-13 -1.5,-19 C -1.0,-22 -0.3,-23 0,-23
               L 0,-23 C -0.3,-20 -0.6,-13 -1.0,-7 Z"
            fill="url(#bot-leafLt)" opacity="0.55"/>
      <line x1="0" y1="-3" x2="0" y2="-23" stroke="#56683e" stroke-width="0.28" opacity="0.55"/>
    </symbol>

    <!-- Green olive fruit -->
    <symbol id="bot-olive-g" overflow="visible">
      <ellipse cx="0" cy="0" rx="4" ry="5.6" fill="url(#bot-oliveG)" stroke="#3e4a26" stroke-width="0.5"/>
      <ellipse cx="-1.2" cy="-1.8" rx="1" ry="1.6" fill="rgba(245,250,210,0.55)"/>
    </symbol>

    <!-- Dark/purple olive fruit -->
    <symbol id="bot-olive-d" overflow="visible">
      <ellipse cx="0" cy="0" rx="4" ry="5.6" fill="url(#bot-oliveD)" stroke="#0a060e" stroke-width="0.5"/>
      <ellipse cx="-1.2" cy="-1.8" rx="0.9" ry="1.4" fill="rgba(180,160,210,0.45)"/>
    </symbol>

    <!-- ─────────────────────────────────────────────────────────
         REUSABLE: White Lily (full bloom, ~50px across)
         Reference: 6 petals with curved tips, 6 brown anthers,
                    yellow-green stigma, brown speckles near center
         ───────────────────────────────────────────────────────── -->
    <symbol id="bot-lily" overflow="visible">
      <!-- Petal shape: long, pointed, slightly waved tip -->
      <g>
        <!-- Outer ring of 3 petals (slightly behind) -->
        <path d="M 0,0 C 3.5,-5 8,-15 9,-28 C 10,-38 6,-44 2.5,-44
                 C 1.5,-44 0.5,-42 0,-38 L 0,-38
                 C -0.5,-42 -1.5,-44 -2.5,-44 C -6,-44 -10,-38 -9,-28
                 C -8,-15 -3.5,-5 0,0 Z"
              fill="url(#bot-petalShade)" stroke="#c4ba9e" stroke-width="0.55" opacity="0.85" transform="rotate(60)"/>
        <path d="M 0,0 C 3.5,-5 8,-15 9,-28 C 10,-38 6,-44 2.5,-44
                 C 1.5,-44 0.5,-42 0,-38 L 0,-38
                 C -0.5,-42 -1.5,-44 -2.5,-44 C -6,-44 -10,-38 -9,-28
                 C -8,-15 -3.5,-5 0,0 Z"
              fill="url(#bot-petalShade)" stroke="#c4ba9e" stroke-width="0.55" opacity="0.85" transform="rotate(180)"/>
        <path d="M 0,0 C 3.5,-5 8,-15 9,-28 C 10,-38 6,-44 2.5,-44
                 C 1.5,-44 0.5,-42 0,-38 L 0,-38
                 C -0.5,-42 -1.5,-44 -2.5,-44 C -6,-44 -10,-38 -9,-28
                 C -8,-15 -3.5,-5 0,0 Z"
              fill="url(#bot-petalShade)" stroke="#c4ba9e" stroke-width="0.55" opacity="0.85" transform="rotate(300)"/>
        <!-- Inner ring of 3 petals (in front, brighter) -->
        <g transform="rotate(0)">
          <path d="M 0,0 C 4,-5 9,-16 10,-30 C 11,-40 6,-46 2.5,-46
                   C 1.2,-46 0.4,-43 0,-39 L 0,-39
                   C -0.4,-43 -1.2,-46 -2.5,-46 C -6,-46 -11,-40 -10,-30
                   C -9,-16 -4,-5 0,0 Z"
                fill="url(#bot-petal)" stroke="#d4ccb6" stroke-width="0.6"/>
          <!-- subtle petal vein -->
          <path d="M 0,-4 C 0.5,-14 0.8,-26 0.6,-40" fill="none" stroke="#e8e2d2" stroke-width="0.45" opacity="0.7"/>
          <!-- brown speckles near base -->
          <circle cx="-1.8" cy="-10" r="0.45" fill="#5e3820" opacity="0.7"/>
          <circle cx="2.2"  cy="-12" r="0.4"  fill="#5e3820" opacity="0.65"/>
          <circle cx="-0.8" cy="-15" r="0.35" fill="#5e3820" opacity="0.6"/>
          <circle cx="1.8"  cy="-18" r="0.35" fill="#5e3820" opacity="0.55"/>
          <circle cx="-1.5" cy="-22" r="0.3"  fill="#5e3820" opacity="0.5"/>
        </g>
        <g transform="rotate(120)">
          <path d="M 0,0 C 4,-5 9,-16 10,-30 C 11,-40 6,-46 2.5,-46
                   C 1.2,-46 0.4,-43 0,-39 L 0,-39
                   C -0.4,-43 -1.2,-46 -2.5,-46 C -6,-46 -11,-40 -10,-30
                   C -9,-16 -4,-5 0,0 Z"
                fill="url(#bot-petal)" stroke="#d4ccb6" stroke-width="0.6"/>
          <path d="M 0,-4 C 0.5,-14 0.8,-26 0.6,-40" fill="none" stroke="#e8e2d2" stroke-width="0.45" opacity="0.7"/>
          <circle cx="-1.8" cy="-10" r="0.45" fill="#5e3820" opacity="0.7"/>
          <circle cx="2.2"  cy="-12" r="0.4"  fill="#5e3820" opacity="0.65"/>
          <circle cx="-0.8" cy="-15" r="0.35" fill="#5e3820" opacity="0.6"/>
        </g>
        <g transform="rotate(240)">
          <path d="M 0,0 C 4,-5 9,-16 10,-30 C 11,-40 6,-46 2.5,-46
                   C 1.2,-46 0.4,-43 0,-39 L 0,-39
                   C -0.4,-43 -1.2,-46 -2.5,-46 C -6,-46 -11,-40 -10,-30
                   C -9,-16 -4,-5 0,0 Z"
                fill="url(#bot-petal)" stroke="#d4ccb6" stroke-width="0.6"/>
          <path d="M 0,-4 C 0.5,-14 0.8,-26 0.6,-40" fill="none" stroke="#e8e2d2" stroke-width="0.45" opacity="0.7"/>
          <circle cx="-1.8" cy="-10" r="0.45" fill="#5e3820" opacity="0.7"/>
          <circle cx="2.2"  cy="-12" r="0.4"  fill="#5e3820" opacity="0.65"/>
          <circle cx="-0.8" cy="-15" r="0.35" fill="#5e3820" opacity="0.6"/>
        </g>
        <!-- ── 6 stamens with brown anthers (THE distinctive lily feature) ── -->
        <g>
          <g transform="rotate(15)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
          <g transform="rotate(75)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
          <g transform="rotate(135)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
          <g transform="rotate(195)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
          <g transform="rotate(255)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
          <g transform="rotate(315)">
            <path d="M 0,-1 Q 1,-12 2,-22" fill="none" stroke="#a8b27a" stroke-width="0.55"/>
            <ellipse cx="2.5" cy="-23" rx="0.9" ry="2.3" fill="#5a2f12" stroke="#2e1808" stroke-width="0.3" transform="rotate(18 2.5 -23)"/>
          </g>
        </g>
        <!-- ── Pistil (central, taller, green stigma) ── -->
        <line x1="0" y1="-1" x2="0.5" y2="-26" stroke="#88a058" stroke-width="0.75"/>
        <ellipse cx="0.5" cy="-27" rx="1.1" ry="1.6" fill="#9eb060" stroke="#5e7034" stroke-width="0.3"/>
        <!-- ── Yellow-green throat (center) ── -->
        <circle cx="0" cy="-1" r="2.8" fill="#c8c870" opacity="0.55"/>
        <circle cx="0" cy="-1" r="1.6" fill="#8aa040" opacity="0.6"/>
      </g>
    </symbol>

    <!-- ── Closed lily bud (elongated green pod) ── -->
    <symbol id="bot-bud" overflow="visible">
      <!-- bud body -->
      <path d="M 0,0 C -3,-2 -5,-8 -4.5,-16 C -4,-22 -2,-24 0,-24
               C 2,-24 4,-22 4.5,-16 C 5,-8 3,-2 0,0 Z"
            fill="url(#bot-bud)" stroke="#2c3a18" stroke-width="0.45"/>
      <!-- highlight stripe -->
      <path d="M -1.5,-4 C -1,-10 -0.5,-16 0,-22" fill="none" stroke="#a8c078" stroke-width="0.4" opacity="0.6"/>
      <!-- darker shadow stripe -->
      <path d="M 1.8,-4 C 2.2,-10 2.4,-16 2,-22" fill="none" stroke="#2c3a18" stroke-width="0.35" opacity="0.55"/>
    </symbol>

    <!-- ── Baby's breath cluster (multi-flower puff) ── -->
    <symbol id="bot-bb-cluster" overflow="visible">
      <!-- main stem -->
      <path d="M 0,0 C -3,-8 -6,-16 -10,-24" fill="none" stroke="#7a8a64" stroke-width="0.7" stroke-linecap="round"/>
      <path d="M 0,0 C 0,-9 0,-18 0,-28"     fill="none" stroke="#7a8a64" stroke-width="0.7" stroke-linecap="round"/>
      <path d="M 0,0 C 3,-8 6,-16 10,-24"    fill="none" stroke="#7a8a64" stroke-width="0.7" stroke-linecap="round"/>
      <!-- secondary stems -->
      <path d="M -10,-24 C -13,-30 -16,-36 -19,-42" fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <path d="M -10,-24 C -8,-30 -5,-36 -3,-42"    fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <path d="M 0,-28 C -3,-34 -5,-40 -6,-46"      fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <path d="M 0,-28 C 3,-34 5,-40 6,-46"          fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <path d="M 10,-24 C 8,-30 5,-36 3,-42"          fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <path d="M 10,-24 C 13,-30 16,-36 19,-42"       fill="none" stroke="#8a9874" stroke-width="0.5" stroke-linecap="round"/>
      <!-- LARGER flower puffs at branch tips -->
      <g transform="translate(-19,-43)">
        <circle cx="0" cy="0" r="3.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.45"/>
        <circle cx="-2.4" cy="-1" r="2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="2.2" cy="-0.6" r="2.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="0.5" cy="-2.6" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="-1.2" cy="2" r="1.6" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="1.8" cy="1.8" r="1.5" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
      <g transform="translate(-3,-43)">
        <circle cx="0" cy="0" r="3.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.45"/>
        <circle cx="-2.4" cy="-1" r="2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="2.2" cy="-0.6" r="2.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="0.5" cy="-2.6" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="-1.2" cy="2" r="1.6" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="1.8" cy="1.8" r="1.5" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
      <g transform="translate(-6,-47)">
        <circle cx="0" cy="0" r="2.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.4"/>
        <circle cx="-2" cy="-0.8" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="2" cy="-0.5" r="2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="0.4" cy="-2.4" r="1.6" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="-1" cy="1.8" r="1.4" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
      <g transform="translate(6,-47)">
        <circle cx="0" cy="0" r="2.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.4"/>
        <circle cx="-2" cy="-0.8" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="2" cy="-0.5" r="2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="0.4" cy="-2.4" r="1.6" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="-1" cy="1.8" r="1.4" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
      <g transform="translate(3,-43)">
        <circle cx="0" cy="0" r="3" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.4"/>
        <circle cx="-2" cy="-0.7" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="2" cy="-0.5" r="1.9" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="0.3" cy="-2.4" r="1.5" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
      <g transform="translate(19,-43)">
        <circle cx="0" cy="0" r="3.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.45"/>
        <circle cx="-2.4" cy="-1" r="2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="2.2" cy="-0.6" r="2.2" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="0.5" cy="-2.6" r="1.8" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.35"/>
        <circle cx="-1.2" cy="2" r="1.6" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
        <circle cx="1.8" cy="1.8" r="1.5" fill="url(#bot-bb)" stroke="#bcb29a" stroke-width="0.3"/>
      </g>
    </symbol>

    <!-- ─────────────────────────────────────────────────────────
         REUSABLE: full botanical arrangement (one side)
         ───────────────────────────────────────────────────────── -->
    <symbol id="bot-arrangement" viewBox="0 0 130 620" overflow="visible">
      <!-- watercolor wash backdrop (very faint) -->
      <ellipse cx="80" cy="200" rx="60" ry="180" fill="#e8dfd0" opacity="0.08"/>
      <ellipse cx="60" cy="470" rx="55" ry="160" fill="#d8d0c0" opacity="0.07"/>

      <g filter="url(#bot-soft)">
        <!-- ═══ MAIN OLIVE BRANCH — flowing curve from top-right to bottom-left ═══ -->
        <!-- shadow layer (slightly darker, offset) -->
        <path d="M 112,2 C 104,32 96,66 98,108 C 100,148 84,178 80,220
                 C 76,260 84,300 72,344 C 60,388 50,432 56,478
                 C 62,524 50,572 36,612"
              fill="none" stroke="#2a3618" stroke-width="2.6"
              stroke-linecap="round" stroke-linejoin="round" opacity="0.45"/>
        <!-- main branch -->
        <path d="M 112,2 C 104,32 96,66 98,108 C 100,148 84,178 80,220
                 C 76,260 84,300 72,344 C 60,388 50,432 56,478
                 C 62,524 50,572 36,612"
              fill="none" stroke="#5a6c40" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round"/>
        <!-- highlight -->
        <path d="M 112,2 C 104,32 96,66 98,108 C 100,148 84,178 80,220
                 C 76,260 84,300 72,344 C 60,388 50,432 56,478
                 C 62,524 50,572 36,612"
              fill="none" stroke="#a8b48a" stroke-width="0.5"
              stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>

        <!-- ── Sub-branch for upper cluster ── -->
        <path d="M 102,38 C 92,32 78,28 64,30" fill="none" stroke="#5a6c40" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M 102,38 C 92,32 78,28 64,30" fill="none" stroke="#2a3618" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>
        <!-- ── Sub-branch for middle cluster ── -->
        <path d="M 88,180 C 76,176 60,170 46,172" fill="none" stroke="#5a6c40" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M 88,180 C 76,176 60,170 46,172" fill="none" stroke="#2a3618" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>
        <!-- ── Sub-branch for lower olives ── -->
        <path d="M 70,358 C 58,354 44,350 32,354" fill="none" stroke="#5a6c40" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M 70,358 C 58,354 44,350 32,354" fill="none" stroke="#2a3618" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>
        <!-- ── Sub-branch for bottom cluster ── -->
        <path d="M 54,540 C 42,544 28,548 18,554" fill="none" stroke="#5a6c40" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M 54,540 C 42,544 28,548 18,554" fill="none" stroke="#2a3618" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>

        <!-- ════════ UPPER CLUSTER (y≈20-90): leaves + olive ════════ -->
        <use href="#bot-leaf"     x="108" y="20" transform="rotate(80 108 20)"/>
        <use href="#bot-leaf"     x="105" y="34" transform="rotate(105 105 34)"/>
        <use href="#bot-leaf-sm"  x="86"  y="32" transform="rotate(118 86 32)"/>
