<%- include('partials/head', { pageTitle: 'Share Your Photos', config }) %>
<% var activePage = 'upload'; %>
<%- include('partials/nav', { config: config, activePage: activePage }) %>

<main id="main-content">
  <section class="page-hero">
    <div class="container">
      <h1>Share Your Photos</h1>
      <p class="page-hero-sub">Upload your memories from our celebration</p>
    </div>
  </section>

  <section class="form-section">
    <div class="container container--narrow">

      <% if (flash) { %>
        <div class="alert alert--<%= flash.type %>" role="alert">
          <%= flash.message %>
        </div>
      <% } %>

      <% if (!flash || flash.type !== 'success') { %>

      <% var limitReached = (typeof photoCount === 'number' && typeof photoLimit === 'number' && photoCount >= photoLimit); %>
      <% var remaining    = (typeof photoCount === 'number' && typeof photoLimit === 'number') ? (photoLimit - photoCount) : null; %>

      <% if (limitReached) { %>
        <div class="upload-limit-reached" role="alert">
          <p class="upload-limit-icon" aria-hidden="true">📷</p>
          <p class="upload-limit-title">Photo limit reached</p>
          <p>You've uploaded all <%= photoLimit %> photos allowed per guest — thank you for sharing so many memories with us!</p>
          <a href="/gallery" class="btn btn-secondary" style="margin-top:1rem;">View the Gallery</a>
        </div>
      <% } else { %>

      <div class="upload-info">
        <p>Share your photos from our wedding day! You can upload up to <%= MAX_FILES %> photos at once. All photos are reviewed and must be approved before they appear in the public gallery — only approved photos will be visible to other guests.</p>
        <ul class="upload-rules">
          <li>JPEG, PNG, or WebP images only</li>
          <li>Maximum file size: <%= MAX_SIZE_MB %> MB per photo</li>
          <li>Up to <%= MAX_FILES %> photos per submission</li>
          <li>Up to <%= photoLimit %> photos total per guest name<% if (remaining !== null) { %> &mdash; <strong><%= remaining %> remaining</strong><% } %></li>
          <li>Photos require approval before appearing in the gallery</li>
        </ul>
      </div>

      <form action="/upload" method="post" enctype="multipart/form-data" class="wedding-form" id="upload-form" novalidate
            data-max-mb="<%= MAX_SIZE_MB %>" data-max-files="<%= MAX_FILES %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label for="photos" class="form-label">
            Choose Photos <span class="required" aria-hidden="true">*</span>
          </label>
          <div class="file-drop-zone" id="drop-zone" role="button" tabindex="0" aria-label="Click to choose photos or drag and drop">
            <div class="drop-zone-content" id="drop-zone-content">
              <span class="drop-icon" aria-hidden="true">📷</span>
              <span class="drop-text">Click to choose photos or drag &amp; drop here</span>
              <span class="drop-sub">JPEG, PNG, or WebP &bull; Max <%= MAX_SIZE_MB %> MB each &bull; Up to <%= MAX_FILES %> photos</span>
            </div>
            <div id="preview-grid" hidden></div>
          </div>
          <input
            type="file"
            id="photos"
            name="photos"
            accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp"
            multiple
            required
            class="file-input-hidden"
            aria-describedby="file-hint"
          >
          <p id="file-hint" class="form-hint">Only image files are accepted. Photos will be reviewed before appearing publicly.</p>
        </div>

        <div class="form-group">
          <label for="uploader_name" class="form-label">Your Name <span class="optional">(optional)</span></label>
          <input
            type="text"
            id="uploader_name"
            name="uploader_name"
            class="form-input"
            maxlength="100"
            placeholder="How should we credit these photos?"
          >
        </div>

        <div class="form-group">
          <label for="uploader_message" class="form-label">Caption or Message <span class="optional">(optional)</span></label>
          <textarea
            id="uploader_message"
            name="uploader_message"
            class="form-textarea"
            maxlength="500"
            rows="3"
            placeholder="Add a caption or message for your photos..."
          ></textarea>
          <p class="form-hint">Your caption will be displayed alongside your photos in the gallery once approved.</p>
        </div>

        <button type="submit" class="btn btn-primary btn--full" id="submit-btn">
          Upload Photos
        </button>
      </form>

      <% } %>

      <% } %>

    </div>
  </section>
</main>

<style>
  .upload-limit-reached {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--warm-white, #faf6f0);
    border: 1px solid rgba(184,148,90,0.2);
    border-radius: 10px;
    margin-bottom: 2rem;
  }
  .upload-limit-icon  { font-size: 3rem; margin-bottom: 0.8rem; }
  .upload-limit-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--brown, #3d2b1f);
    margin-bottom: 0.6rem;
  }

  /* Multi-file preview grid */
  #preview-grid {
    padding: 0.75rem 0.5rem 0.5rem;
    width: 100%;
    box-sizing: border-box;
  }
  .preview-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    padding: 0 0.25rem;
  }
  .preview-count {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brown, #3d2b1f);
  }
  .preview-clear-btn {
    background: none;
    border: 1px solid rgba(184,148,90,0.5);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    color: var(--brown, #3d2b1f);
    cursor: pointer;
  }
  .preview-clear-btn:hover { background: rgba(184,148,90,0.1); }
  .preview-thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 0.5rem;
  }
  .preview-card {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(0,0,0,0.04);
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .preview-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .preview-card-name {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0,0,0,0.55);
    color: #fff;
    font-size: 0.65rem;
    padding: 0.15rem 0.3rem;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .preview-card-remove {
    position: absolute;
    top: 3px;
    right: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.6);
    color: #fff;
    border: none;
    font-size: 0.9rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .preview-card-remove:hover { background: rgba(200,0,0,0.75); }
  .preview-add-more {
    border: 2px dashed rgba(184,148,90,0.4);
    border-radius: 6px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    cursor: pointer;
    font-size: 1.5rem;
    color: rgba(184,148,90,0.7);
    background: transparent;
    gap: 0.2rem;
  }
  .preview-add-more span { font-size: 0.65rem; color: var(--brown, #3d2b1f); }
  .preview-add-more:hover { background: rgba(184,148,90,0.07); }
</style>

<script src="/js/upload.js?v=4"></script>
<%- include('partials/footer', { config: config }) %>
