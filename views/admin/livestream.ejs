<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Livestream Settings — Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="admin-body">

<header class="admin-header">
  <div class="admin-header-inner">
    <h1 class="admin-header-title">Livestream Settings</h1>
    <nav class="admin-nav" aria-label="Admin navigation">
      <a href="/admin/dashboard" class="admin-nav-link">Dashboard</a>
      <a href="/" class="admin-nav-link" target="_blank" rel="noopener noreferrer">View Site ↗</a>
      <a href="/admin/logout" class="admin-nav-link admin-nav-link--logout">Sign Out</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container" style="max-width:640px;">

    <% if (flash) { %>
      <div class="alert alert--<%= flash.type %>" role="alert"><%= flash.message %></div>
    <% } %>

    <section class="admin-section">
      <h2 class="admin-section-title">Livestream Settings</h2>
      <div class="admin-settings-card">
        <form action="/admin/livestream" method="post" class="admin-settings-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="admin-settings-row">
            <label class="admin-settings-label" for="livestream_channel">Twitch Channel Name</label>
            <input
              type="text"
              id="livestream_channel"
              name="livestream_channel"
              class="admin-settings-input"
              value="<%= siteSettings.livestream_channel %>"
              placeholder="e.g. yourchannelname"
              maxlength="100"
            >
            <p class="admin-settings-hint">The Twitch channel to embed. Leave blank if not set up yet.</p>
          </div>

          <div class="admin-settings-row">
            <label class="admin-checkbox-label">
              <input
                type="checkbox"
                name="livestream_visible"
                value="1"
                <%= siteSettings.livestream_visible === '1' ? 'checked' : '' %>
              >
              <span>Show "Watch Live" link &amp; page to guests</span>
            </label>
            <p class="admin-settings-hint">When unchecked, guests are redirected away from /livestream.</p>
          </div>

          <div class="admin-settings-row">
            <label class="admin-checkbox-label">
              <input
                type="checkbox"
                name="livestream_homepage"
                value="1"
                <%= siteSettings.livestream_homepage === '1' ? 'checked' : '' %>
              >
              <span>Embed livestream player on home page</span>
            </label>
            <p class="admin-settings-hint">Shows the Twitch player directly on the home page (requires channel name above).</p>
          </div>

          <div class="admin-settings-row">
            <button type="submit" class="admin-btn admin-btn--primary">Save Settings</button>
            <a href="/admin/dashboard" class="admin-btn admin-btn--secondary" style="margin-left:0.75rem;">Back to Dashboard</a>
          </div>
        </form>
      </div>
    </section>

  </div>
</main>

</body>
</html>
