<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="admin-body">

<header class="admin-header">
  <div class="admin-header-inner">
    <h1 class="admin-header-title">Admin Dashboard</h1>
    <nav class="admin-nav" aria-label="Admin navigation">
      <a href="/admin/dashboard" class="admin-nav-link admin-nav-link--active">Dashboard</a>
      <a href="/" class="admin-nav-link" target="_blank" rel="noopener noreferrer">View Site ↗</a>
      <a href="/admin/logout" class="admin-nav-link admin-nav-link--logout">Sign Out</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container">

    <% if (flash) { %>
      <div class="alert alert--<%= flash.type %>" role="alert"><%= flash.message %></div>
    <% } %>

    <!-- Stats summary -->
    <div class="admin-stats">
      <div class="admin-stat">
        <span class="admin-stat-num"><%= photoStats.pending %></span>
        <span class="admin-stat-label">Pending Photos</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-num"><%= photoStats.approved %></span>
        <span class="admin-stat-label">Approved</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-num"><%= photoStats.rejected %></span>
        <span class="admin-stat-label">Rejected</span>
      </div>
    </div>

    <!-- ── Livestream Settings ─────────────────────────────────────────────── -->
    <section class="admin-section" aria-labelledby="livestream-heading">
      <h2 class="admin-section-title" id="livestream-heading">&#128250; Livestream Settings</h2>
      <div class="admin-settings-card">
        <form action="/admin/livestream" method="post" class="admin-settings-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="admin-settings-row">
            <label class="admin-settings-label" for="livestream_channel">Twitch Channel Name</label>
            <input
              type="text"
              id="livestream_channel"
              name="livestream_channel"
              class="admin-settings-input"
              value="<%= siteSettings.livestream_channel %>"
              placeholder="e.g. yourchannelname"
              maxlength="100"
            >
            <p class="admin-settings-hint">Leave blank if no channel is set up yet.</p>
          </div>

          <div class="admin-settings-row">
            <label class="admin-checkbox-label">
              <input
                type="checkbox"
                name="livestream_visible"
                value="1"
                <%= siteSettings.livestream_visible === '1' ? 'checked' : '' %>
              >
              <span>Show "Watch Live" link, tile &amp; page to guests</span>
            </label>
          </div>

          <div class="admin-settings-row">
            <label class="admin-checkbox-label">
              <input
                type="checkbox"
                name="livestream_homepage"
                value="1"
                <%= siteSettings.livestream_homepage === '1' ? 'checked' : '' %>
              >
              <span>Embed livestream player directly on home page</span>
            </label>
          </div>

          <div class="admin-settings-row" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
            <button type="submit" class="admin-btn admin-btn--primary">Save Livestream Settings</button>
            <% if (siteSettings.livestream_visible === '1' && siteSettings.livestream_channel) { %>
              <a href="/livestream" target="_blank" rel="noopener noreferrer"
                 class="admin-btn admin-btn--secondary">Preview Livestream Page ↗</a>
            <% } %>
          </div>
        </form>
      </div>
    </section>

    <!-- ── Google Drive Integration ─────────────────────────────────────── -->
    <section class="admin-section" aria-labelledby="drive-heading">
      <h2 class="admin-section-title" id="drive-heading">&#128194; Google Drive Backup</h2>
      <div class="admin-settings-card">

        <div class="admin-settings-row" style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
          <% if (driveConfigured) { %>
            <span class="badge badge--approved">&#10003; Service account connected</span>
          <% } else { %>
            <span class="badge badge--warning">&#33; Service account not set</span>
            <p class="admin-settings-hint" style="margin:0.5rem 0 0;">
              Set the <code>GOOGLE_SERVICE_ACCOUNT_JSON</code> environment variable in Railway
              (raw JSON or base64-encoded). The service account must have <em>Editor</em>
              access on the target folder.
            </p>
          <% } %>
        </div>

        <form action="/admin/settings/drive" method="post" class="admin-settings-form" style="margin-top:1.25rem;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="admin-settings-row">
            <label class="admin-settings-label" for="google_drive_folder_url">
              Google Drive Folder URL <span class="optional">(or Folder ID)</span>
            </label>
            <input
              type="text"
              id="google_drive_folder_url"
              name="google_drive_folder_url"
              class="admin-settings-input"
              value="<%= siteSettings.google_drive_folder_id %>"
              placeholder="https://drive.google.com/drive/folders/… or just the folder ID"
            >
            <p class="admin-settings-hint">
              Paste the full folder URL from your browser or just the folder ID.
              Approved photos are automatically uploaded to this folder.
            </p>
          </div>

          <div class="admin-settings-row">
            <button type="submit" class="admin-btn admin-btn--primary">Save Drive Settings</button>
          </div>
        </form>

      </div>
    </section>

    <!-- ── Site Images ────────────────────────────────────────────────────── -->
    <section class="admin-section" aria-labelledby="site-images-heading">
      <h2 class="admin-section-title" id="site-images-heading">&#128444; Site Images</h2>
      <p class="admin-section-note">Images available at <code>/images/&lt;filename&gt;</code>. You can upload multiple at once, replace an existing image in-place, or delete it.</p>

      <!-- Upload new site images (multi-file) -->
      <form action="/admin/site-image/upload" method="post" enctype="multipart/form-data"
            class="admin-settings-card" style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;padding:1.25rem 1.5rem;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="admin-settings-label" style="margin:0;white-space:nowrap;">Upload Images</label>
        <input type="file" name="site_images" accept="image/jpeg,image/png,image/webp,image/gif"
               multiple required style="color:#c8c4d8;flex:1;min-width:200px;">
        <button type="submit" class="admin-btn admin-btn--primary">Upload</button>
      </form>

      <!-- Existing site images grid -->
      <% if (siteImages && siteImages.length > 0) { %>
        <div class="admin-site-image-grid" style="margin-top:1rem;">
          <% siteImages.forEach(function(img) { %>
            <div class="admin-site-image-card">
              <div class="admin-site-image-thumb">
                <img src="/images/<%= encodeURIComponent(img) %>" alt="<%= img %>" loading="lazy">
              </div>
              <div class="admin-site-image-info">
                <p class="admin-site-image-name" title="<%= img %>"><%= img %></p>
                <div style="display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center;">
                  <!-- Replace in-place -->
                  <form action="/admin/site-image/<%= encodeURIComponent(img) %>/replace" method="post"
                        enctype="multipart/form-data" class="replace-form" style="display:contents;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <label class="admin-btn admin-btn--secondary admin-btn--sm replace-label" style="cursor:pointer;margin:0;">
                      &#8635; Replace
                      <input type="file" name="replacement"
                             accept="image/jpeg,image/png,image/webp,image/gif"
                             class="replace-input" style="display:none;"
                             onchange="this.closest('form').submit()">
                    </label>
                  </form>
                  <!-- Delete -->
                  <form action="/admin/site-image/<%= encodeURIComponent(img) %>/delete" method="post" style="margin:0;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="admin-btn admin-btn--danger admin-btn--sm"
                            onclick="return confirm('Delete <%= img %>?')">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="admin-empty" style="margin-top:1rem;">No site images uploaded yet.</div>
      <% } %>
    </section>

    <!-- ── Pending Photos ─────────────────────────────────────────────────── -->
    <section class="admin-section" aria-labelledby="pending-heading">
      <div class="admin-section-header">
        <h2 class="admin-section-title" id="pending-heading">
          &#9203; Pending Photos
          <% if (photoStats.pending > 0) { %>
            <span class="badge badge--warning"><%= photoStats.pending %></span>
          <% } %>
        </h2>
        <% if (pendingPhotos && pendingPhotos.length > 0) { %>
          <div class="admin-bulk-controls" id="bulk-controls">
            <button type="button" class="admin-btn admin-btn--secondary admin-btn--sm" id="select-all-btn">Select all</button>
          </div>
        <% } %>
      </div>

      <% if (pendingPhotos && pendingPhotos.length > 0) { %>
        <p class="admin-section-note">Review guest photos. Click a photo to preview it in full. Tick boxes and use the action bar to approve or reject in bulk.</p>

        <!-- Hidden bulk action form -->
        <form id="bulk-form" action="/admin/photos/bulk-action" method="post" style="display:none;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="action" id="bulk-action-input" value="">
        </form>

        <div class="admin-photo-grid" id="pending-grid">
          <% pendingPhotos.forEach(function(photo) { %>
            <div class="admin-photo-card admin-photo-card--selectable" data-photo-id="<%= photo.id %>">
              <label class="admin-photo-select-wrap" aria-label="Select photo by <%= photo.uploader_name || 'anonymous' %>">
                <input type="checkbox" class="photo-checkbox" value="<%= photo.id %>">
                <span class="admin-photo-checkmark" aria-hidden="true"></span>
              </label>
              <button type="button"
                      class="admin-photo-thumb admin-photo-preview-btn"
                      data-src="/admin/photo/<%= photo.id %>/image"
                      data-caption="<%= photo.uploader_name || 'Anonymous' %><%= photo.uploaded_at ? ' · ' + new Date(photo.uploaded_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '' %>"
                      aria-label="Preview photo by <%= photo.uploader_name || 'anonymous' %>">
                <img class="admin-photo-img"
                     src="/admin/photo/<%= photo.id %>/image"
                     alt="Photo by <%= photo.uploader_name || 'anonymous' %>"
                     loading="lazy">
              </button>
              <div class="admin-photo-info">
                <div class="admin-photo-meta">
                  <strong><%= photo.uploader_name || 'Anonymous' %></strong><br>
                  <span class="admin-photo-date"><%= photo.uploaded_at ? new Date(photo.uploaded_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : 'Unknown date' %></span><br>
                  <span class="admin-photo-size"><%= photo.file_size ? Math.round(photo.file_size/1024) + ' KB' : '' %></span>
                </div>
                <% if (photo.uploader_message) { %>
                  <p class="admin-photo-msg">"<%= photo.uploader_message %>"</p>
                <% } %>
                <div class="admin-photo-actions">
                  <form action="/admin/photo/<%= photo.id %>/approve" method="post" style="flex:1;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-approve btn--full-width">&#10003; Approve</button>
                  </form>
                  <form action="/admin/photo/<%= photo.id %>/reject" method="post" style="flex:1;" class="reject-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-reject btn--full-width">&#10007; Reject</button>
                  </form>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="admin-empty">No photos pending review.</div>
      <% } %>
    </section>

    <!-- Bulk action bar (shown when ≥1 checkbox checked) -->
    <div class="admin-bulk-bar" id="bulk-bar" hidden aria-live="polite">
      <span class="admin-bulk-bar-count" id="bulk-bar-count">0 selected</span>
      <button type="button" class="admin-btn admin-btn--sm btn-approve" id="bulk-approve-btn">&#10003; Approve selected</button>
      <button type="button" class="admin-btn admin-btn--sm btn-reject"  id="bulk-reject-btn">&#10007; Reject selected</button>
      <button type="button" class="admin-btn admin-btn--sm admin-btn--ghost" id="bulk-clear-btn">Clear</button>
    </div>

    <!-- ── Approved Photos ────────────────────────────────────────────────── -->
    <section class="admin-section" aria-labelledby="approved-heading">
      <h2 class="admin-section-title" id="approved-heading">&#10003; Approved Photos</h2>

      <% if (approvedPhotos && approvedPhotos.length > 0) { %>
        <p class="admin-section-note">Feature photos to show them on the home page. Unfeature or delete as needed.</p>
        <div class="admin-photo-grid">
          <% approvedPhotos.forEach(function(photo) { %>
            <div class="admin-photo-card admin-photo-card--approved<%= photo.featured ? ' admin-photo-card--featured' : '' %>">
              <% if (photo.featured) { %>
                <div class="admin-featured-badge">&#9733; Featured on Home</div>
              <% } %>
              <button type="button"
                      class="admin-photo-thumb admin-photo-preview-btn"
                      data-src="/uploads/approved/<%= encodeURIComponent(photo.filename) %>"
                      data-caption="<%= photo.uploader_name || 'Anonymous' %><%= photo.reviewed_at ? ' · ' + new Date(photo.reviewed_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '' %>"
                      aria-label="Preview photo by <%= photo.uploader_name || 'anonymous' %>">
                <img class="admin-photo-img"
                     src="/uploads/approved/<%= encodeURIComponent(photo.filename) %>"
                     alt="Photo by <%= photo.uploader_name || 'anonymous' %>"
                     loading="lazy">
              </button>
              <div class="admin-photo-info">
                <div class="admin-photo-meta">
                  <strong><%= photo.uploader_name || 'Anonymous' %></strong>
                  <span class="badge badge--approved">Approved</span><br>
                  <span class="admin-photo-date"><%= photo.reviewed_at ? new Date(photo.reviewed_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '' %></span>
                </div>
                <% if (photo.uploader_message) { %>
                  <p class="admin-photo-msg">"<%= photo.uploader_message %>"</p>
                <% } %>
                <div class="admin-photo-actions" style="flex-direction:column;gap:0.4rem;">
                  <% if (!photo.featured) { %>
                    <form action="/admin/photo/<%= photo.id %>/feature" method="post">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn-feature btn--full-width">&#9733; Feature on Home</button>
                    </form>
                  <% } else { %>
                    <form action="/admin/photo/<%= photo.id %>/unfeature" method="post">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn-unfeature btn--full-width">&#9734; Remove from Home</button>
                    </form>
                  <% } %>
                  <form action="/admin/photo/<%= photo.id %>/delete" method="post">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn-reject btn--full-width btn-reject.btn--full-width"
                            onclick="return confirm('Remove this photo from the public gallery?')">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="admin-empty">No approved photos yet. Approve photos from the Pending section above.</div>
      <% } %>
    </section>

  </div>
</main>

<!-- Admin photo lightbox -->
<div class="lightbox" id="admin-lightbox" hidden role="dialog" aria-modal="true" aria-label="Photo preview">
  <div class="lightbox-inner">
    <img class="lightbox-img" id="admin-lightbox-img" src="" alt="">
    <p class="lightbox-caption" id="admin-lightbox-caption"></p>
  </div>
  <button class="lightbox-close" id="admin-lightbox-close" aria-label="Close preview">&#10005;</button>
  <button class="lightbox-prev" id="admin-lightbox-prev" aria-label="Previous photo">&#8249;</button>
  <button class="lightbox-next" id="admin-lightbox-next" aria-label="Next photo">&#8250;</button>
</div>

<script src="/js/admin.js?v=2"></script>
</body>
</html>
