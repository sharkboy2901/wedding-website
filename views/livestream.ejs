<%- include('partials/head', { pageTitle: 'Watch Live', config }) %>
<% const activePage = 'livestream'; %>
<%- include('partials/nav', { config, activePage, livestreamVisible }) %>
<%- include('partials/botanicals') %>

<main>
  <section class="page-hero">
    <div class="container">
      <h1>Watch Live</h1>
      <p class="page-hero-sub">Join us from wherever you are</p>
    </div>
  </section>

  <section class="form-section">
    <div class="container container--narrow">

      <% if (channel) { %>

        <div class="livestream-wrap">
          <div class="livestream-player">
            <iframe
              src="https://player.twitch.tv/?channel=<%= encodeURIComponent(channel) %>&parent=mk-wedding.up.railway.app&autoplay=false&muted=false"
              height="480"
              width="100%"
              allowfullscreen
              frameborder="0"
              scrolling="no"
              title="Wedding livestream on Twitch"
              style="border-radius:8px;display:block;"
            ></iframe>
          </div>
          <div class="livestream-meta">
            <p class="livestream-note">
              <span class="livestream-icon" aria-hidden="true">📡</span>
              Watching <strong><%= channel %></strong> on Twitch
            </p>
            <p class="livestream-hint">
              If the stream hasn't started yet, the player will show offline. Check back closer to the ceremony.
              You can also watch directly on <a href="https://twitch.tv/<%= encodeURIComponent(channel) %>" target="_blank" rel="noopener noreferrer">Twitch</a>.
            </p>
          </div>
        </div>

      <% } else { %>

        <div class="livestream-placeholder">
          <div class="livestream-placeholder-icon" aria-hidden="true">📺</div>
          <h2 class="livestream-placeholder-title">Livestream coming soon</h2>
          <p class="livestream-placeholder-text">
            The livestream will be available here on <strong>June 6th</strong>.
            Come back on the day to watch the ceremony live from wherever you are.
          </p>
          <a href="/" class="btn btn-secondary" style="margin-top:1.5rem;">Return Home</a>
        </div>

      <% } %>

    </div>
  </section>
</main>

<style>
  .livestream-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .livestream-player {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(61,43,31,0.13);
    background: #000;
    aspect-ratio: 16 / 9;
  }

  .livestream-player iframe {
    width: 100%;
    height: 100%;
    border-radius: 10px;
    display: block;
  }

  .livestream-meta {
    text-align: center;
  }

  .livestream-note {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--brown, #3d2b1f);
    margin-bottom: 0.6rem;
  }

  .livestream-icon {
    margin-right: 0.4rem;
  }

  .livestream-hint {
    font-size: 0.875rem;
    color: var(--brown-light, #7a5c47);
    line-height: 1.6;
  }

  .livestream-hint a {
    color: var(--gold, #b8945a);
    text-decoration: underline;
  }

  .livestream-placeholder {
    text-align: center;
    padding: 4rem 1rem;
  }

  .livestream-placeholder-icon {
    font-size: 4rem;
    margin-bottom: 1.2rem;
    opacity: 0.7;
  }

  .livestream-placeholder-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--brown, #3d2b1f);
    margin-bottom: 0.8rem;
  }

  .livestream-placeholder-text {
    font-size: 1rem;
    color: var(--brown-light, #7a5c47);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  @media (min-width: 700px) {
    .livestream-player {
      aspect-ratio: 16 / 9;
    }
  }
</style>

<%- include('partials/footer', { config }) %>
